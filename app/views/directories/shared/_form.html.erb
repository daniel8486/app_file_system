<%= form_with(model: directory) do |form| %>
  <% if directory.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(directory.errors.count, "erro") %>:</h2>
      <ul>
        <% directory.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= form.label :name, "Nome" %>
    <%= form.text_field :name %>
  </div>
  <div>
    <%= form.label :parent_id, "Diretório Pai" %>
    <%= form.collection_select :parent_id, Directory.all, :id, :name, include_blank: true %>
  </div>
  <div>
    <%= form.submit %>
  </div>
<% end %>